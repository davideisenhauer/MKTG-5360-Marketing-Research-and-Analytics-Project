##Chi test:
# Load packages
library(ggplot2)
library(tidyr)
library(scales)

# CONTINGENCY TABLE
# Familiarity vs Motivation

fam_mot_tab <- matrix(
  c(22, 5,   # Familiar Yes: Motivated Yes, No
    5, 7),   # Familiar No: Motivated Yes, No
  nrow = 2,
  byrow = TRUE
)

rownames(fam_mot_tab) <- c("Familiar_Yes", "Familiar_No")
colnames(fam_mot_tab) <- c("Motivated_Yes", "Motivated_No")

# View table
print(fam_mot_tab)

# CHI-SQUARE TEST

chisq_result <- chisq.test(fam_mot_tab)

print(chisq_result)
print(chisq_result$expected)

# APA-style output
cat(
  sprintf(
    "χ²(%d, N = %d) = %.2f, p = %.3f\n",
    chisq_result$parameter,
    sum(fam_mot_tab),
    unname(chisq_result$statistic),
    chisq_result$p.value
  )
)

# Optional: Fisher’s Exact Test (for small sample robustness)
fisher_result <- fisher.test(fam_mot_tab)
print(fisher_result)

# PREP DATA FOR GRAPHS

plot_data <- as.data.frame(fam_mot_tab)
plot_data$Familiarity <- rownames(plot_data)

plot_data_long <- pivot_longer(
  plot_data,
  cols = c("Motivated_Yes", "Motivated_No"),
  names_to = "Motivation",
  values_to = "Count"
)

print(plot_data_long)

# GRAPH 1: Grouped Bar Chart

p1 <- ggplot(plot_data_long, aes(x = Familiarity, y = Count, fill = Motivation)) +
  geom_col(position = "dodge") +
  labs(
    title = "Familiarity vs Motivation to Shop at ReStore",
    x = "Familiar with Habitat",
    y = "Number of Respondents",
    fill = "Motivation"
  ) +
  theme_minimal()

print(p1)

# GRAPH 2: 100% Stacked Bar Chart

p2 <- ggplot(plot_data_long, aes(x = Familiarity, y = Count, fill = Motivation)) +
  geom_col(position = "fill") +
  scale_y_continuous(labels = percent_format()) +
  labs(
    title = "Proportion Motivated to Shop by Familiarity",
    x = "Familiar with Habitat",
    y = "Percent",
    fill = "Motivation"
  ) +
  theme_minimal()

print(p2)

