library(readxl)
library(dplyr)
library(ggplot2)
library(scales)
library(tidyr)

file_path <- "/Users/davideisenhauer/Downloads/MKTG 5360 Quant Analysis.xlsx"

# Read the sheet with the class-level cross-tab counts
by_class <- read_excel(file_path, sheet = "By Class", col_names = FALSE)

# Academic classification x Would donate if bins were placed around campus
donation_tab <- matrix(
  c(5, 2,   # Freshman: Yes, No
    3, 4,   # Sophomore: Yes, No
    13, 6,  # Junior: Yes, No
    4, 0),  # Senior: Yes, No
  nrow = 4,
  byrow = TRUE
)

rownames(donation_tab) <- c("Freshman", "Sophomore", "Junior", "Senior")
colnames(donation_tab) <- c("Yes", "No")

# Chi-square test
chisq_result <- chisq.test(donation_tab)

# Fisher's exact test (useful because of small expected counts / zero cell)
fisher_result <- fisher.test(donation_tab)

# View outputs
print(by_class)
print(donation_tab)
print(chisq_result)
print(chisq_result$expected)
print(fisher_result)

# APA-style reporting line
cat(
  sprintf(
    "Chi-square test: χ²(%d, N = %d) = %.2f, p = %.3f\n",
    chisq_result$parameter,
    sum(donation_tab),
    unname(chisq_result$statistic),
    chisq_result$p.value
  )
)

cat(
  sprintf(
    "Fisher's Exact Test p-value = %.3f\n",
    fisher_result$p.value
  )
)

# Convert to data frame
plot_data <- as.data.frame(donation_tab)
plot_data$Classification <- rownames(plot_data)

# Convert wide to long format for ggplot
plot_data_long <- pivot_longer(
  plot_data,
  cols = c("Yes", "No"),
  names_to = "Donate",
  values_to = "Count"
)

print(plot_data_long)

# Graph 1: Grouped bar chart
ggplot(plot_data_long, aes(x = Classification, y = Count, fill = Donate)) +
